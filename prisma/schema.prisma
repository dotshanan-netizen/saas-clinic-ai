// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

enum EntityStatus {
  ACTIVE
  INACTIVE
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum KbCategory {
  FAQ
  POLICY
  GENERAL_INFO
}

enum KnowledgeStatus {
  DRAFT
  REVIEW
  APPROVED
  PUBLISHED
  ARCHIVED
}

model Clinic {
  id                  String         @id @default(cuid())
  name                String
  slug                String         @unique
  logoUrl             String?
  description         String?        @db.Text
  contactPhone        String?
  customPrompt        String?        @db.Text
  welcomeMessage      String?        @db.Text
  operatingHours      String?        @db.Text
  
  // WhatsApp Meta Cloud API Configuration
  whatsappPhoneId     String?
  whatsappToken       String?        @db.Text
  whatsappWabaId      String?
  whatsappVerifyToken String?
  isAiActive          Boolean        @default(true)

  createdAt           DateTime       @default(now())
  branches            Branch[]
  doctors             Doctor[]
  services            Service[]
  bookings            Booking[]
  conversations       Conversation[]
  knowledgeBase       KnowledgeBase[]
  knowledgeDocuments  KnowledgeDocument[]
}

model Branch {
  id             String         @id @default(cuid())
  name           String
  city           String         @default("الرياض")
  address        String
  phone          String?
  status         EntityStatus   @default(ACTIVE)
  clinicId       String
  clinic         Clinic         @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  doctors        DoctorBranch[]
  workingHours   WorkingHour[]
  createdAt      DateTime       @default(now())

  @@index([clinicId])
  @@index([status])
}

model WorkingHour {
  id        String   @id @default(cuid())
  branchId  String
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  dayOfWeek String   // e.g. "MONDAY", "TUESDAY", etc.
  startTime String   // e.g. "09:00"
  endTime   String   // e.g. "17:00"
  isClosed  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@unique([branchId, dayOfWeek])
  @@index([branchId])
}

model Doctor {
  id        String         @id @default(cuid())
  name      String
  specialty String
  imageUrl  String?
  status    EntityStatus   @default(ACTIVE)
  clinicId  String
  clinic    Clinic         @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  branches  DoctorBranch[]
  services  DoctorService[]
  createdAt DateTime       @default(now())

  @@index([clinicId])
  @@index([status])
}

model Service {
  id              String          @id @default(cuid())
  name            String
  description     String?         @db.Text
  price           Float
  durationMinutes Int             @default(30)
  status          EntityStatus    @default(ACTIVE)
  clinicId        String
  clinic          Clinic          @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  doctors         DoctorService[]
  createdAt       DateTime        @default(now())

  @@index([clinicId])
  @@index([status])
}

// Join model for Doctor-Branch relationship
model DoctorBranch {
  id       String @id @default(cuid())
  doctorId String
  doctor   Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  branchId String
  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([doctorId, branchId])
  @@index([doctorId])
  @@index([branchId])
}

// Join model for Doctor-Service relationship
model DoctorService {
  id        String  @id @default(cuid())
  doctorId  String
  doctor    Doctor  @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  serviceId String
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([doctorId, serviceId])
  @@index([doctorId])
  @@index([serviceId])
}

model KnowledgeBase {
  id        String     @id @default(cuid())
  category  KbCategory
  content   String     @db.Text
  clinicId  String
  clinic    Clinic     @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  createdAt DateTime   @default(now())

  @@index([clinicId])
  @@index([createdAt])
}

model KnowledgeDocument {
  id          String          @id @default(cuid())
  title       String
  category    KbCategory
  language    String          @default("ar")
  version     Int             @default(1)
  source      String?         // e.g., "Pricing.pdf", "Manual Entry"
  status      KnowledgeStatus @default(DRAFT)
  
  // Metadata for filtering
  clinicId    String
  branchId    String?
  doctorId    String?

  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  chunks      KnowledgeChunk[]
  clinic      Clinic          @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  
  @@index([clinicId, status])
}

model KnowledgeChunk {
  id          String            @id @default(cuid())
  documentId  String
  document    KnowledgeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  
  content     String            @db.Text
  embedding   Unsupported("vector(768)")?

  @@index([documentId])
}

model Booking {
  id          String        @id @default(cuid())
  clientName  String
  clientPhone String
  serviceName String
  doctorName  String
  branchName  String
  timeSlot    String
  source      String        // e.g. "Snapchat", "Instagram", "Google", "Simulator"
  status      BookingStatus @default(PENDING)
  clinicId    String
  clinic      Clinic        @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  createdAt   DateTime      @default(now())

  @@index([clinicId])
  @@index([status])
  @@index([createdAt])
}

model Conversation {
  id          String   @id @default(cuid())
  clientPhone String
  messages    Json     // Array of message objects {role: "user"|"assistant", content: string, timestamp: Date}
  clinicId    String
  clinic      Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  @@unique([clinicId, clientPhone])
  @@index([clinicId])
  @@index([updatedAt])
}

model ProcessedWebhook {
  id        String   @id // The wamid from Meta
  clinicId  String
  createdAt DateTime @default(now())

  @@index([clinicId])
}

model JobTracker {
  id          String    @id @default(cuid())
  jobId       String    @unique // BullMQ Job ID
  type        String    // e.g., "incoming-message"
  status      JobStatus @default(PENDING)
  payload     Json
  attempts    Int       @default(0)
  error       String?   @db.Text
  startedAt   DateTime?
  finishedAt  DateTime?
  createdAt   DateTime  @default(now())
}