# Template for Cloudflare Named Tunnel
# Copy this file to cloudflared.config.yml and replace values in <> with your local settings.

tunnel: <TUNNEL_UUID>
credentials-file: C:/Users/<USERNAME>/.cloudflared/<TUNNEL_UUID>.json

ingress:
  - hostname: dev-webhook.clinova.ai
    service: http://localhost:3000
  - service: http_status:404
